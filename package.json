{
	"name": "@rodrigodagostino/svelte-sortable-list",
	"description": "Create accessible, sortable lists in Svelte, with keyboard, mouse, and touch support.",
	"version": "1.2.2",
	"author": "Rodrigo D’Agostino <rodrigo.dagostino@proton.me>",
	"keywords": [
		"sortable",
		"list",
		"drag",
		"drop",
		"dnd",
		"touch",
		"sort",
		"reorder",
		"reorderable",
		"accessible",
		"a11y",
		"svelte",
		"sveltekit",
		"component"
	],
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rodrigodagostino/svelte-sortable-list.git"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "playwright test",
		"test:debug": "playwright test --debug",
		"test:headed": "playwright test --headed",
		"test:ui": "playwright test --ui",
		"test:trace": "playwright test --trace on",
		"test:trigger-flaky": "playwright test --repeat-each=20 --workers=4 -x"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./*.css": {
			"import": "./dist/*.css"
		}
	},
	"peerDependencies": {
		"svelte": "^4.0.0 || ^5.0.0"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@playwright/test": "1.61.1",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/kit": "2.69.1",
		"@sveltejs/package": "2.5.8",
		"@sveltejs/vite-plugin-svelte": "3.1.2",
		"@types/eslint": "9.6.1",
		"@types/node": "^22",
		"autoprefixer": "10.5.2",
		"eslint": "10.6.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-prettier": "5.5.6",
		"eslint-plugin-svelte": "3.20.0",
		"globals": "17.7.0",
		"postcss": "8.5.16",
		"prettier": "3.9.4",
		"prettier-plugin-svelte": "3.5.2",
		"prettier-plugin-tailwindcss": "0.8.0",
		"publint": "0.3.21",
		"svelte": "4.2.20",
		"svelte-check": "4.7.1",
		"tailwindcss": "3.4.19",
		"typescript": "6.0.3",
		"typescript-eslint": "8.62.1",
		"vite": "5.4.21"
	}
}
